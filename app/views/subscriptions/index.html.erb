<% @subscriptions.each do |sub| %>
  <div>
    <div class="text-gray-600 mb-4">
      You are currently subscribed to the
      <span class="font-semibold text-pink-600">
        <%= SubscriptionType.of_subscription(sub).name %>
      </span> plan.
    </div>
    <div class="text-left mb-4">
      <p class="text-gray-600">
        <span class="font-semibold">Renewal Date:</span>
        <%= sub.current_period_end.strftime('%B %d, %Y') %>
      </p>
      <p class="text-gray-600">
        <span class="font-semibold">Price:</span>
        <span class="text-pink-600">
          <%= SubscriptionType.of_subscription(sub).price %>/<%= SubscriptionType.of_subscription(sub).recurrence %>
        </span>
      </p>
    </div>
  </div>
<% end %>
