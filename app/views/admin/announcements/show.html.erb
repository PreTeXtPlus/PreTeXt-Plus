<% content_for :title, @announcement.title %>

<div class="w-full mx-auto p-4 md:w-5/6">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-semibold"><%= @announcement.title %></h1>
      <p class="mt-2 text-sm text-gray-500">
        <% if @announcement.published? %>
          Published on <%= local_time_tag(@announcement.published_at, date_only: true) %>
        <% elsif @announcement.draft? %>
          <span class="font-medium text-yellow-700">Draft</span> &mdash; not ready to publish
        <% else %>
          <span class="font-medium text-blue-700">Ready to publish</span> &mdash; not yet published
        <% end %>
        <% if @announcement.paid_subscribers_only? %>
          &mdash; <span class="font-medium text-amber-600">Paid subscribers only</span>
        <% end %>
      </p>
    </div>
    <div class="flex gap-2 flex-wrap justify-end">
      <% unless @announcement.published? %>
        <% if @announcement.draft? %>
          <span class="rounded-md px-3.5 py-2 bg-gray-100 text-gray-400 font-medium cursor-not-allowed" title="Uncheck &quot;Keep as draft&quot; and save before publishing">
            Publish & email users
          </span>
        <% else %>
          <%= button_to "Publish & email users", publish_admin_announcement_path(@announcement), method: :post,
                class: "rounded-md px-3.5 py-2 bg-green-600 hover:bg-green-500 text-white font-medium",
                data: { turbo_confirm: @announcement.paid_subscribers_only? ? "This will email paid subscribers only. Proceed?" : "This will email all subscribed users. Proceed?" } %>
        <% end %>
        <%= link_to "Edit", edit_admin_announcement_path(@announcement), class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
      <% end %>
      <%= button_to "Delete", admin_announcement_path(@announcement), method: :delete,
            class: "rounded-md px-3.5 py-2 bg-red-100 hover:bg-red-50 text-red-700 font-medium",
            data: { turbo_confirm: "Delete this announcement?" } %>
      <%= link_to "All announcements", admin_announcements_path, class: "rounded-md px-3.5 py-2 bg-gray-100 hover:bg-gray-50 text-gray-800 font-medium" %>
    </div>
  </div>

  <div class="mt-6 rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
    <div class="prose prose-gray max-w-none text-gray-800">
      <%= sanitize Commonmarker.to_html(@announcement.body) %>
    </div>
  </div>

  <div class="mt-4 rounded-xl border border-gray-200 bg-gray-50 p-5">
    <h2 class="text-sm font-medium text-gray-700">Raw body (Markdown)</h2>
    <pre class="mt-2 text-sm text-gray-600 whitespace-pre-wrap"><%= @announcement.body %></pre>
  </div>
</div>
