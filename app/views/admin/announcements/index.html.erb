<% content_for :title, "Admin announcements" %>

<div class="w-full mx-auto p-4 md:w-5/6">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-semibold">Announcements</h1>
      <p class="mt-2 text-gray-600">Create and publish announcements. Published announcements are emailed to all subscribed users.</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "New announcement", new_admin_announcement_path, class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
      <%= link_to "Back to dashboard", admin_root_path, class: "rounded-md px-3.5 py-2 bg-gray-100 hover:bg-gray-50 text-gray-800 font-medium" %>
    </div>
  </div>

  <div class="mt-6 overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr class="text-left text-gray-600">
          <th class="px-4 py-3 font-medium">Title</th>
          <th class="px-4 py-3 font-medium">Status</th>
          <th class="px-4 py-3 font-medium">Published</th>
          <th class="px-4 py-3 font-medium">Created</th>
          <th class="px-4 py-3 font-medium"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @announcements.each do |announcement| %>
          <tr>
            <td class="px-4 py-4 font-medium text-gray-900">
              <%= link_to announcement.title, admin_announcement_path(announcement), class: "text-blue-600 hover:underline" %>
            </td>
            <td class="px-4 py-4">
              <% if announcement.published? %>
                <span class="rounded-full bg-green-100 px-2.5 py-1 text-xs font-medium text-green-800">Published</span>
              <% elsif announcement.draft? %>
                <span class="rounded-full bg-yellow-100 px-2.5 py-1 text-xs font-medium text-yellow-800">Work-in-progress</span>
              <% else %>
                <span class="rounded-full bg-blue-100 px-2.5 py-1 text-xs font-medium text-blue-800">Ready to publish</span>
              <% end %>
            </td>
            <td class="px-4 py-4 text-gray-700">
              <%= announcement.published_at&.to_date || "—" %>
            </td>
            <td class="px-4 py-4 text-gray-700"><%= announcement.created_at.to_date %></td>
            <td class="px-4 py-4">
              <%= link_to "Edit", edit_admin_announcement_path(announcement), class: "text-blue-600 hover:underline text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @announcements.empty? %>
      <p class="p-6 text-gray-600">No announcements yet.</p>
    <% end %>
  </div>
</div>
