<% content_for :title, "New announcement" %>

<div class="w-full mx-auto p-4 md:w-5/6 lg:w-2/3">
  <div class="flex items-center justify-between gap-4 mb-6">
    <h1 class="text-3xl font-semibold">New announcement</h1>
    <%= link_to "All announcements", admin_announcements_path, class: "rounded-md px-3.5 py-2 bg-gray-100 hover:bg-gray-50 text-gray-800 font-medium" %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <%= render "form", announcement: @announcement %>
  </div>
</div>
