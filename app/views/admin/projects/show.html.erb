<% content_for :title, @project.title %>

<div class="w-full mx-auto p-4 md:w-5/6">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-semibold"><%= @project.title %></h1>
      <p class="mt-2 text-gray-600">
        Read-only support view for this project. Owner:
        <%= link_to @project.user.email, admin_user_path(@project.user), class: "text-blue-600 hover:underline" %>
      </p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Back to user", admin_user_path(@project.user), class: "rounded-md px-3.5 py-2 bg-gray-100 hover:bg-gray-50 text-gray-800 font-medium" %>
      <%= link_to "Rendered share view", share_project_path(@project), class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium", target: "_blank", rel: "noopener" %>
      <%= link_to "Shared source", share_source_project_path(@project), class: "rounded-md px-3.5 py-2 bg-gray-100 hover:bg-gray-50 text-gray-800 font-medium", target: "_blank", rel: "noopener" %>
    </div>
  </div>

  <section class="mt-8 grid gap-4 xl:grid-cols-4">
    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium uppercase tracking-wide text-gray-500">Source format</p>
      <p class="mt-3 text-xl font-semibold text-gray-900"><%= @project.source_format.to_s.humanize %></p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium uppercase tracking-wide text-gray-500">Document type</p>
      <p class="mt-3 text-xl font-semibold text-gray-900"><%= @project.document_type.to_s.humanize %></p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium uppercase tracking-wide text-gray-500">Created</p>
      <p class="mt-3 text-lg font-semibold text-gray-900"><%= @project.created_at.to_date %></p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium uppercase tracking-wide text-gray-500">Updated</p>
      <p class="mt-3 text-lg font-semibold text-gray-900"><%= time_ago_in_words(@project.updated_at) %> ago</p>
    </div>
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-2">
    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-semibold">Source preview</h2>
      <pre class="mt-4 overflow-x-auto rounded-lg bg-gray-950 p-4 text-sm text-gray-100"><%= truncate(@project.source.to_s, length: 1500) %></pre>
    </div>

    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-semibold">PreTeXt preview</h2>
      <% if @project.pretext_source.present? %>
        <pre class="mt-4 overflow-x-auto rounded-lg bg-gray-950 p-4 text-sm text-gray-100"><%= truncate(@project.pretext_source, length: 1500) %></pre>
      <% else %>
        <p class="mt-4 text-gray-600">No converted PreTeXt source stored for this project.</p>
      <% end %>
    </div>
  </section>
</div>
