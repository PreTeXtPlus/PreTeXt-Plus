<!DOCTYPE html>
<html>
  <head>
    <title>PreTeXt.Plus<% if content_for(:title).present? %> | <%= content_for(:title) %><% end %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pretext Plus">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <nav class="bg-white px-6 py-4 w-full shadow border-b border-gray-200 md:fixed md:z-10 md:top-0 md:left-0 md:h-16 z-10">
        <div class="flex flex-col container mx-auto md:flex-row md:items-center md:justify-between">
            <div class="flex justify-between items-center">
                <div>
                  <%= link_to :root, class: "flex items-center" do %>
                      <img src="/icon.svg" class="h-6 mr-3 sm:h-9" alt="PreTeXtPlus Logo">
                      <span class="self-center text-xl font-semibold whitespace-nowrap">PreTeXt.Plus (beta)</span>
                  <% end %>
                </div>
            </div>
            <div class="flex flex-col md:flex-row md:-mx-4">
                <% if current_user.present? %>
                  <%= link_to :projects, class: "my-1 text-gray-800 hover:text-blue-500 md:mx-4 md:my-0" do %>
                    Projects
                  <% end %>
                <% end %>
                <%= link_to :root, class: "my-1 text-gray-800 hover:text-blue-500 md:mx-4 md:my-0" do %>
                  About
                <% end %>
                <%= link_to announcements_path, class: "my-1 text-gray-800 hover:text-blue-500 md:mx-4 md:my-0" do %>
                  Announcements
                <% end %>
                <% if current_user.present? %>
                  <div class="relative group">
                    <label for="helpMenuToggle" class="my-1 text-gray-800 cursor-pointer hover:text-blue-500 md:mx-4 md:my-0 select-none">
                      Help&nbsp;&#9662;
                    </label>
                    <input type="checkbox" id="helpMenuToggle" class="navbarMenuToggle sr-only">
                    <div class="navbarMenu absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-gray-200 md:left-auto md:right-0">
                      <a href="https://pretextbook.org/examples/sample-article/annotated/" target="_blank" class="block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500 rounded-t-md">
                        PreTeXt Sample Article
                      </a>
                      <a href="https://pretextbook.org/doc/guide/html/" target="_blank" class="block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500">
                        PreTeXt Guide
                      </a>
                      <a href="mailto:support@pretext.plus" target="_blank" class="block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500">
                        Email Support
                      </a>
                    </div>
                  </div>
                <% end %>
                <% if current_user&.admin? %>
                  <div class="relative group">
                    <label for="adminMenu" class="my-1 text-gray-800 cursor-pointer hover:text-blue-500 md:mx-4 md:my-0 select-none">
                      Admin&nbsp;&#9662;
                    </label>
                    <input type="checkbox" id="adminMenu" class="navbarMenuToggle sr-only">
                    <div class="navbarMenu absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-gray-200 md:left-auto md:right-0">
                      <%= link_to admin_root_path, class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500" do %>
                        Dashboard
                      <% end %>
                      <%= link_to admin_users_path, class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500" do %>
                        Users
                      <% end %>
                      <%= link_to admin_announcements_path, class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500" do %>
                        Announcements
                      <% end %>
                      <%= link_to subscription_types_path, class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500" do %>
                        Subscription Types
                      <% end %>
                      <%= link_to new_admin_term_path, class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500" do %>
                        Update Terms
                      <% end %>
                    </div>
                  </div>
                <% end %>
                <% if current_user.present? %>
                  <div class="relative group">
                    <label for="accountMenu" class="my-1 text-gray-800 cursor-pointer hover:text-blue-500 md:mx-4 md:my-0 select-none">
                    Account&nbsp;(<%= current_user.email %>)&nbsp;&#9662;
                    </label>
                    <input type="checkbox" id="accountMenu" class="navbarMenuToggle sr-only">
                    <div class="navbarMenu absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-gray-200 md:left-auto md:right-0">
                      <%= link_to edit_user_path(current_user), class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500" do %>
                        Profile
                      <% end %>
                      <%= link_to subscriptions_path, class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500" do %>
                        Manage Subscriptions
                      <% end %>
                      <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-4 py-2 text-red-700 hover:bg-red-50 hover:text-red-800" do %>
                        Sign out
                      <% end %>
                    </div>
                  </div>
                <% else %>
                  <div class="relative group">
                    <label for="accountMenu" class="my-1 text-gray-800 cursor-pointer hover:text-blue-500 md:mx-4 md:my-0 select-none">
                    Account&nbsp;&#9662;
                    </label>
                    <input type="checkbox" id="accountMenu" class="navbarMenuToggle sr-only">
                    <div class="navbarMenu absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-gray-200 md:left-auto md:right-0">
                      <%= link_to new_user_path, class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500" do %>
                        Create account
                      <% end %>
                      <%= link_to new_user_session_path, class: "block px-4 py-2 text-gray-800 hover:bg-blue-50 hover:text-blue-500" do %>
                        Sign in
                      <% end %>
                    </div>
                  </div>
                  <%= link_to tryit_path, class: "my-1 text-gray-800 hover:text-blue-500 md:mx-4 md:my-0", data: { turbo: false } do %>
                    Try it!
                  <% end %>
                <% end %>
            </div>
        </div>
    </nav>
      <% if notice.present? or params[:notice].present? or alert.present? %>
        <div class="relative flex justify-center w-full cursor-pointer -mb-20 bg-white" onclick="this.remove()">
          <% if notice.present? or params[:notice].present? %>
            <div class="mt-20 mb-2 rounded-lg border border-blue-200 bg-blue-50 px-4 py-2 text-blue-800 text-sm w-full md:w-2/3 flex justify-between">
              <span>
                <span>
                  <svg class="inline mr-2" width="24px" height="24px" stroke-width="1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor"><path d="M14 14V6M14 14L20.1023 17.487C20.5023 17.7156 21 17.4268 21 16.9661V3.03391C21 2.57321 20.5023 2.28439 20.1023 2.51296L14 6M14 14H7C4.79086 14 3 12.2091 3 10V10C3 7.79086 4.79086 6 7 6H14" stroke="currentColor" stroke-width="1"></path><path d="M7.75716 19.3001L7 14H11L11.6772 18.7401C11.8476 19.9329 10.922 21 9.71716 21C8.73186 21 7.8965 20.2755 7.75716 19.3001Z" stroke="currentColor" stroke-width="1"></path></svg>
                </span>
                <%= notice or params[:notice] %>
              </span>
              <span><svg width="24px" height="24px" stroke-width="1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6.75827 17.2426L12.0009 12M17.2435 6.75736L12.0009 12M12.0009 12L6.75827 6.75736M12.0009 12L17.2435 17.2426" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            </div>
          <% else %>
            <div class="mt-20 mb-2 rounded-lg border border-yellow-200 bg-yellow-50 px-4 py-2 text-yellow-800 text-sm w-full md:w-2/3 flex justify-between">
              <span>
                <span>
                  <svg class="inline mr-2" width="24px" height="24px" stroke-width="1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor"><path d="M20.0429 21H3.95705C2.41902 21 1.45658 19.3364 2.22324 18.0031L10.2662 4.01533C11.0352 2.67792 12.9648 2.67791 13.7338 4.01532L21.7768 18.0031C22.5434 19.3364 21.581 21 20.0429 21Z" stroke="currentColor" stroke-width="1" stroke-linecap="round"></path><path d="M12 9V13" stroke="currentColor" stroke-width="1" stroke-linecap="round"></path><path d="M12 17.01L12.01 16.9989" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </span>
                <%= alert %>
              </span>
              <span><svg width="24px" height="24px" stroke-width="1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6.75827 17.2426L12.0009 12M17.2435 6.75736L12.0009 12M12.0009 12L6.75827 6.75736M12.0009 12L17.2435 17.2426" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            </div>
          <% end %>
        </div>
      <% end %>
        <% if content_for?(:full_screen_content) %>
          <main class="md:pt-16 md:h-screen">
            <%= yield(:full_screen_content) %>
          </main>
        <% else %>
          <div class="md:pt-16 md:min-h-screen bg-gray-50">
            <main class="w-full md:min-h-[80vh] bg-white">
              <%= content_for?(:content) ? yield(:content) : yield %>
            </main>
            <footer class="w-full p-3 h-1/8 text-center">
              <p>© 2025-<%= Time.current.year %> PreTeXt Plus LLC</p>
              <div class="flex gap-3 justify-center">
                <% if Term.current(:tos).present? %>
                  <%= link_to "Terms of Service", tos_path, class: "text-gray-800 hover:text-gray-900 hover:underline" %>
                <% end %>
                <span>|</span>
                <% if Term.current(:privacy).present? %>
                  <%= link_to "Privacy Policy", privacy_path, class: "text-gray-800 hover:text-gray-900 hover:underline" %>
                <% end %>
              </div>
            </footer>
          </div>
        <% end %>
  </body>
</html>
