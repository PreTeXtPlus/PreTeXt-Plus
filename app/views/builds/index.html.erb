<% content_for :title, "Builds — #{@project.title}" %>

<div class="w-full mx-auto p-4 md:w-2/3">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-semibold">Builds</h1>
      <p class="mt-1 text-gray-600">
        <%= link_to @project.title, @project, class: "hover:underline" %>
      </p>
    </div>
    <%= button_to "New Build", project_builds_path(@project),
          method: :post, params: { build: {} },
          class: "rounded-md px-3.5 py-2 bg-green-600 hover:bg-green-500 text-white font-medium cursor-pointer" %>
  </div>

  <% if @builds.any? %>
    <div class="mt-6 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Status</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Format</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Created</th>
            <th class="px-4 py-3"></th>
            <th class="px-4 py-3"></th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @builds.each do |build| %>
            <tr>
              <td class="px-4 py-3 text-sm"><%= build_status_badge(build) %></td>
              <td class="px-4 py-3 text-sm text-gray-600">
                HTML
              </td>
              <td class="px-4 py-3 text-sm text-gray-600">
                <%= local_time_tag(build.created_at, relative: true) %>
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <% if build.success? %>
                  <%= link_to "Visit Site", build_file_path(build, "index.html"),
                        class: "text-blue-600 hover:underline" %>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <% if build.success? %>
                  <%= link_to "Download ZIP", rails_blob_path(build.zip, disposition: "attachment"),
                        class: "text-sky-600 hover:underline", data: {turbo: false} %>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <%= link_to "Details", project_build_path(@project, build),
                      class: "text-indigo-600 hover:underline", data: {turbo: false} %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="mt-8 text-gray-600">No builds yet.</p>
  <% end %>
</div>
