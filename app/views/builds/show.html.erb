<% content_for :title, "Build — #{@project.title}" %>

<div class="w-full mx-auto p-4 md:w-2/3">
  <div class="flex items-center gap-4">
    <div>
      <h1 class="text-3xl font-semibold">Build</h1>
      <p class="mt-1 text-gray-600">
        <%= link_to @project.title, @project, class: "hover:underline" %> &rsaquo;
        <%= link_to "Builds", project_builds_path(@project), class: "hover:underline" %>
      </p>
    </div>
  </div>

  <div class="mt-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm space-y-3">
    <div>
      <span class="text-sm font-semibold text-gray-700">Status</span>
      <p class="mt-1"><%= build_status_badge(@build) %></p>
    </div>
    <div>
      <span class="text-sm font-semibold text-gray-700">Created</span>
      <p class="mt-1 text-gray-600">
        <time datetime="<%= @build.created_at.iso8601 %>"><%= @build.created_at.strftime("%B %-d, %Y at %-I:%M %p") %></time>
      </p>
    </div>
    <div>
      <span class="text-sm font-semibold text-gray-700">Files</span>
      <p class="mt-1 text-gray-600"><%= @build.build_files.count %></p>
    </div>
  </div>
</div>
