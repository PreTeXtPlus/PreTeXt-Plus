<%= form_with(model: project_asset, class: "contents") do |form| %>
  <% if project_asset.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(project_asset.errors.count, "error") %> prohibited this project_asset from being saved:</h2>

      <ul class="list-disc ml-6">
        <% project_asset.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :library_asset_id %>
    <%= form.select :library_asset_id, project.user.library_assets.reject { |a| project.library_assets.include? a }.map { |p| [ p.filename, p.id ] } %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
