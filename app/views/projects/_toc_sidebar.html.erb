<%# Sidebar table of contents for multi-element projects %>
<nav class="flex flex-col h-full bg-gray-50 border-r border-gray-200 w-64 shrink-0 overflow-y-auto text-sm"
     data-controller="toc"
     data-toc-project-id-value="<%= project.id %>">
  <div class="px-3 py-2 border-b border-gray-200 flex items-center justify-between">
    <h2 class="font-semibold text-gray-700 truncate"><%= project.title %></h2>
    <%= link_to projects_path, class: "text-gray-400 hover:text-gray-600", title: "Back to projects" do %>
      ←
    <% end %>
  </div>

  <ul class="flex-1 py-1" data-toc-target="tree">
    <%= render partial: "projects/toc_node", collection: tree, as: :node, locals: { project: project, current_element: current_element, depth: 0 } %>
  </ul>

  <div class="px-3 py-2 border-t border-gray-200">
    <button data-action="toc#addElement"
            data-element-type="section"
            class="w-full text-center text-xs text-blue-600 hover:text-blue-800 py-1 rounded hover:bg-blue-50">
      + Add section
    </button>
  </div>
</nav>
