<% content_for :title, "Source for #{@project.title}" %>
<% content_for :full_screen_content do %>
<div class="size-full md:flex md:flex-row">
    <div class="w-full md:w-1/2 md:h-full p-5 flex flex-col">
      <%= button_to "Copy to a new project", 
        copy_project_path(@project), method: :post,
        form_class: "w-full h-[10%] sm:w-auto sm:inline-block",
        class: "w-full text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium cursor-pointer" %>
      <% if @project.user == current_user %>
        <div class="p-3 w-full m-auto text-center text-sm text-gray-500">
          You are the owner of this project
          (<%= link_to "Manage", @project, class: "text-blue-500 hover:font-semibold" %>).
        </div>
      <% end %>
      <h3 class="text-lg mt-5">PreTeXt XML source</h3>
      <textarea class="size-full mt-2 bg-gray-100 font-mono text-gray-800 p-3 resize-none" readonly><%= @project.pretext_source %></textarea>
    </div>
    <div class="w-full md:w-1/2 h-screen md:h-full">
      <%= render @project %>
    </div>
</div>
<% end %>
