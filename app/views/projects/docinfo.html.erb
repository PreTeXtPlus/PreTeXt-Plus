<% content_for :title, "Document Info — #{@project.title}" %>

<div class="w-full px-4 pt-24 pb-12 md:px-0">
  <div class="mx-auto max-w-2xl">
    <div class="flex items-center justify-between mb-2">
      <h1 class="font-bold text-3xl">Document Info</h1>
      <%= link_to "← Back to editor", edit_project_path(@project),
            class: "text-sm text-blue-600 hover:text-blue-800" %>
    </div>
    <p class="text-gray-500 mb-8">
      Configure document-level settings for <strong><%= @project.title %></strong>.
      These are included in the <code>&lt;docinfo&gt;</code> block when your project is built.
    </p>

    <%= form_with model: @project, class: "space-y-8" do |form| %>
      <%# ── Macros ─────────────────────────────────────────────── %>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1" for="project_docinfo_macros">
          LaTeX Macros
        </label>
        <p class="text-xs text-gray-400 mb-2">
          Define custom LaTeX commands available throughout your document.
          These are placed inside <code>&lt;macros&gt;</code> in <code>&lt;docinfo&gt;</code>.
        </p>
        <%= form.text_area :docinfo_macros,
              rows: 8,
              placeholder: "\\newcommand{\\N}{\\mathbb{N}}\n\\newcommand{\\Z}{\\mathbb{Z}}",
              class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm font-mono shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      </div>

      <%# ── LaTeX Image Preamble ───────────────────────────────── %>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1" for="project_docinfo_latex_image_preamble">
          LaTeX Image Preamble
        </label>
        <p class="text-xs text-gray-400 mb-2">
          LaTeX packages and setup for <code>&lt;latex-image&gt;</code> elements (e.g., TikZ).
          These are placed inside <code>&lt;latex-image-preamble&gt;</code> in <code>&lt;docinfo&gt;</code>.
        </p>
        <%= form.text_area :docinfo_latex_image_preamble,
              rows: 8,
              placeholder: "\\usepackage{tikz}\n\\usepackage{pgfplots}",
              class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm font-mono shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      </div>

      <%# ── Submit ───────────────────────────────────────────────── %>
      <div class="flex items-center gap-4 pt-2">
        <%= form.submit "Save document info",
              class: "rounded-md px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
        <%= link_to "Cancel", edit_project_path(@project),
              class: "rounded-md px-5 py-2.5 bg-gray-100 hover:bg-gray-200 font-medium text-gray-700" %>
      </div>
    <% end %>
  </div>
</div>
