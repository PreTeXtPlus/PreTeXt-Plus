<% content_for :title, "Try it!" %>

<% content_for :full_screen_content do %>
<div class="flex size-full flex-1 flex-col min-h-0">

<div class="shrink-0 bg-sky-50/70 ">
  <div class="mx-auto max-w-6xl p-3 md:p-3">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-sky-900">Try it Demo</h1>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "Create account", new_user_path, class: "rounded-md bg-sky-700 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-600" %>
        <%= link_to "Sign in", new_user_session_path, class: "rounded-md border border-sky-400 bg-white px-4 py-2 text-sm font-semibold text-sky-800 hover:bg-sky-100" %>
      </div>
    </div>
  </div>
</div>

<%= render "tryit_form", project: @project %>

</div>
<% end %>
