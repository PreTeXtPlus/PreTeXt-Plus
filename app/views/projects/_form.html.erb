<div class="md:flex md:size-full" data-controller="editor" data-turbo="false">
  <div data-editor-target="root" class="h-screen md:size-full">
    <div class="mx-5">
      PreTeXt.Plus (beta) works best in an updated Chromium-based browser such as Google Chrome or Microsoft Edge.
      If you're seeing this message, please update your browser or switch to Chrome/Edge.
    </div>
  </div>
  <% if local_assigns[:current_element] && current_element %>
    <%# Element-level editing: save targets the individual source element %>
    <%= form_with(model: current_element, url: project_source_element_path(project, current_element), method: :patch, class: "hidden", html: {"data-editor-target" => "form"}) do |form| %>
      <%= hidden_field_tag :title, project.title, "data-editor-target" => "titleField" %>
      <%= form.hidden_field :source, "data-editor-target" => "contentField" %>
      <%= hidden_field_tag :source_format, project.source_format, "data-editor-target" => "sourceFormatField" %>
      <%= form.hidden_field :pretext_source, "data-editor-target" => "pretextSourceField" %>
      <%= hidden_field_tag :token, ENV["BUILD_TOKEN"], "data-editor-target" => "tokenField" %>
      <%= hidden_field_tag :host, ENV["BUILD_HOST"], "data-editor-target" => "hostField" %>
    <% end %>
  <% else %>
    <%# Legacy single-source editing %>
    <%= form_with(model: project, class: "hidden", html: {"data-editor-target" => "form"}) do |form| %>
      <%= form.hidden_field :title, "data-editor-target" => "titleField" %>
      <%= form.hidden_field :source, "data-editor-target" => "contentField" %>
      <%= form.hidden_field :source_format, "data-editor-target" => "sourceFormatField" %>
      <%= form.hidden_field :pretext_source, "data-editor-target" => "pretextSourceField" %>
      <%= form.hidden_field :token, "data-editor-target" => "tokenField", value: ENV["BUILD_TOKEN"] %>
      <%= form.hidden_field :host, "data-editor-target" => "hostField", value: ENV["BUILD_HOST"] %>
    <% end %>
  <% end %>
</div>
