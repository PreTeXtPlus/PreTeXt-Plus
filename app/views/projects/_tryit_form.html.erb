<%
  project_json = {
    title: project.title,
    docinfo: project.docinfo,
    divisions: project.divisions.map { |d|
      { id: d.id || d.ref, ref: d.ref, is_root: d.is_root, source: d.source, source_format: d.source_format }
    }
  }.to_json
%>
<div class="flex size-full flex-1"
     data-controller="tryit"
     data-tryit-project-value="<%= project_json %>">
  <div data-tryit-target="root" class="w-full flex-1 min-h-0">
    <div class="mx-5">
      PreTeXt.Plus (beta) works best in an updated Chromium-based browser such as Google Chrome or Microsoft Edge.
      If you're seeing this message, please update your browser or switch to Chrome/Edge.
    </div>
  </div>
</div>
