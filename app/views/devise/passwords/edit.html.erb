<% content_for :title, "Update Password" %>

<div class="mx-auto md:w-2/3 w-full py-4">
  <h1 class="font-bold text-4xl">Update password</h1>

  <%= form_with(model: resource, as: resource_name, url: password_path(resource_name), html: { method: :put }, data: { turbo: false }) do |form| %>
    <%= form.hidden_field :reset_password_token %>

    <div class="my-5">
      <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password", placeholder: "Enter new password", maxlength: 72, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-solid focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="inline">
      <%= form.submit "Save new password", class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
    </div>
  <% end %>
</div>
