<h1 style="margin-top: 0; color: #333333; font-size: 22px; font-weight: bold; text-align: left;"><%= @announcement.title %></h1>

<div style="color: #51545E; font-size: 16px; line-height: 1.625;">
  <%= sanitize CommonMarker.render_html(@announcement.body, :DEFAULT) %>
</div>

<table style="width: 100%; margin-top: 32px; padding-top: 24px; border-top: 1px solid #EAEAEC;">
  <tr>
    <td style="font-size: 13px; color: #6B6E76; text-align: center;">
      You are receiving this because you have an account on
      <a href="https://pretext.plus" style="color: #3869D4;">PreTeXt.Plus</a>.
      <br>
      <a href="<%= @unsubscribe_url %>" style="color: #6B6E76;">Unsubscribe from announcements</a>
    </td>
  </tr>
</table>
