
<% if form.object.errors.any? %>
    <div class="text-red-600">Error: <%= form.object.errors.full_messages.first %></div>
<% end %>

<div class="my-5">
    <%= form.label :name, class: "text-sm font-semibold text-gray-800" %>
    <%= form.text_field :name, required: true, autofocus: true, autocomplete: "Your Name", placeholder: "Enter your name", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
</div>

<% if form.object.new_record? %>
    <div class="my-5">
        <%= form.label :email, class: "text-sm font-semibold text-gray-800" %>
        <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email@example.com", placeholder: "Enter your email address", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>
    <div class="my-5">
        <%= form.label :password, class: "text-sm font-semibold text-gray-800" do %>
            Choose a secure password
        <% end %>
        <%= form.password_field :password, required: true, placeholder: "Enter a password", maxlength: 72, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>
    <div class="my-5 flex items-start gap-3">
        <%= form.check_box :announcement_emails, checked: false, class: "mt-0.5 h-4 w-4 rounded border-gray-400 text-blue-600 focus:ring-blue-500" %>
        <%= form.label :announcement_emails, class: "text-sm text-gray-700" do %>
            Check this to subscribe to PreTeXt.Plus email updates and announcements!
        <% end %>
    </div>
<% end %>
