<h1 style="font-size: 22px; font-weight: bold; margin: 0 0 16px;">Subscription Digest</h1>
<p style="margin: 0 0 16px; color: #51545E;">
  New subscriptions created since <%= @since.strftime("%B %-d, %Y at %-I:%M %p UTC") %>:
</p>

<% if @subscriptions.any? %>
  <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse; margin-bottom: 24px;">
    <thead>
      <tr style="background-color: #F4F4F7;">
        <th style="text-align: left; padding: 8px 12px; font-size: 13px; color: #6B6E76; border-bottom: 1px solid #E2E2E2;">User</th>
        <th style="text-align: left; padding: 8px 12px; font-size: 13px; color: #6B6E76; border-bottom: 1px solid #E2E2E2;">Plan</th>
        <th style="text-align: left; padding: 8px 12px; font-size: 13px; color: #6B6E76; border-bottom: 1px solid #E2E2E2;">Status</th>
        <th style="text-align: left; padding: 8px 12px; font-size: 13px; color: #6B6E76; border-bottom: 1px solid #E2E2E2;">Seats</th>
        <th style="text-align: left; padding: 8px 12px; font-size: 13px; color: #6B6E76; border-bottom: 1px solid #E2E2E2;">Created</th>
      </tr>
    </thead>
    <tbody>
      <% @subscriptions.each do |sub| %>
        <% user = sub.user rescue nil %>
        <% sub_type = sub.type rescue nil %>
        <tr style="border-bottom: 1px solid #E2E2E2;">
          <td style="padding: 10px 12px; font-size: 14px;">
            <% if user %>
              <%= user.name %><br>
              <span style="color: #6B6E76; font-size: 12px;"><%= user.email %></span>
            <% else %>
              <span style="color: #6B6E76;">—</span>
            <% end %>
          </td>
          <td style="padding: 10px 12px; font-size: 14px;">
            <%= sub_type&.name || sub.processor_plan %>
          </td>
          <td style="padding: 10px 12px; font-size: 14px;">
            <span style="text-transform: capitalize;"><%= sub.status %></span>
          </td>
          <td style="padding: 10px 12px; font-size: 14px;">
            <%= sub.quantity %>
          </td>
          <td style="padding: 10px 12px; font-size: 14px; white-space: nowrap;">
            <%= sub.created_at.strftime("%-m/%-d/%Y %-I:%M %p") %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <p style="font-size: 14px; color: #6B6E76;">
    Total: <strong><%= @subscriptions.count %></strong> new <%= "subscription".pluralize(@subscriptions.count) %>
  </p>
<% else %>
  <p style="color: #6B6E76; font-style: italic;">No new subscriptions in this period.</p>
<% end %>
