<% content_for :title, "Announcements" %>

<div class="w-full mx-auto p-4 md:w-5/6">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-semibold">Announcements</h1>
      <p class="mt-2 text-gray-600">News and updates from the PreTeXt.Plus team.</p>
    </div>
    <div class="flex gap-1">
    <% if user_signed_in? && !current_user.announcement_emails? %>
      <%= button_to "Subscribe to emails", subscribe_announcements_path, method: :post,
            class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
    <% end %>
    <% if can? :manage, Announcement %>
      <%= link_to "Admin", admin_announcements_path,
            class: "rounded-md px-3.5 py-2 bg-sky-600 hover:bg-sky-500 text-white font-medium" %>
    <% end %>
    </div>
  </div>

  <% if @announcements.any? %>
    <div class="mt-8 space-y-4">
      <% @announcements.each do |announcement| %>
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-xl font-semibold text-gray-900">
                <%= link_to announcement.title, announcement_path(announcement), class: "hover:underline" %>
              </h2>
              <p class="mt-1 text-sm text-gray-500">
                <time datetime="<%= announcement.published_at.iso8601 %>"><%= announcement.published_at.to_date %></time>
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="mt-8 text-gray-600">No announcements yet.</p>
  <% end %>
</div>
