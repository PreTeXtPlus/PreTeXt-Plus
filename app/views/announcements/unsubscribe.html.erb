<% content_for :title, "Unsubscribe from announcements" %>

<div class="w-full mx-auto p-4 md:w-3/4 lg:w-1/2">
  <div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm text-center">
    <% if @unsubscribed %>
      <h1 class="text-2xl font-semibold text-gray-900">You've been unsubscribed</h1>
      <p class="mt-4 text-gray-600">
        You will no longer receive announcement emails from PreTeXt.Plus.
        You can resubscribe at any time from your
        <%= link_to "account settings", user_signed_in? ? edit_user_path(current_user) : new_user_session_path, class: "text-blue-600 hover:underline" %>.
      </p>
    <% else %>
      <h1 class="text-2xl font-semibold text-gray-900">Invalid unsubscribe link</h1>
      <p class="mt-4 text-gray-600">
        This unsubscribe link is invalid or has already been used.
        If you need help, contact <a href="mailto:support@pretext.plus" class="text-blue-600 hover:underline">support@pretext.plus</a>.
      </p>
    <% end %>

    <div class="mt-8">
      <%= link_to "View announcements", announcements_path, class: "rounded-md px-3.5 py-2 bg-gray-100 hover:bg-gray-50 text-gray-800 font-medium" %>
    </div>
  </div>
</div>
