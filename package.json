{
  "name": "app",
  "private": true,
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "esbuild": "^0.28.1"
  },
  "scripts": {
    "build": "node -e \"const fs=require('fs');fs.mkdirSync('public/assets',{recursive:true});fs.copyFileSync(require.resolve('@pretextbook/libxslt-wasm/output/libxslt.wasm'),'public/assets/libxslt.wasm')\" && esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --external:module --external:worker_threads"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.20",
    "@pretextbook/web-editor": "^0.16.0",
    "@tanstack/react-query": "^5.101.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "overrides": {
    "dompurify": "^3.3.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
